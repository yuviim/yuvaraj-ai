generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model ContentItem {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  subtitle        String?
  body            String?
  status          String          @default("DRAFT")
  pillar          String
  format          String
  source          String          @default("NATIVE")
  series          Series?         @relation(fields: [seriesId], references: [id])
  seriesId        String?
  tags            String?
  readingTimeMin  Int?
  excerpt         String?
  coverImage      String?
  sourceUrl       String?
  sourceId        String?
  views           Int             @default(0)
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  syncMetadata    SyncMetadata?
}

model Series {
  id              String          @id @default(cuid())
  title           String          @unique
  slug            String          @unique
  description     String?
  pillar          String
  episodeCount    Int             @default(0)
  items           ContentItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model SyncMetadata {
  id              String          @id @default(cuid())
  contentItem     ContentItem     @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  contentItemId   String          @unique
  source          String
  sourceId        String
  sourceUrl       String?
  lastSyncedAt    DateTime        @default(now())
  syncStatus      String?
  syncError       String?
  externalData    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([source, sourceId])
}

model ContentAudit {
  id              String          @id @default(cuid())
  contentItemId   String
  action          String
  status          String?
  pillar          String?
  changedFields   String?
  userId          String?
  createdAt       DateTime        @default(now())
}
